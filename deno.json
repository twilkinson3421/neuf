{
    "name": "@neuf/neuf",
    "version": "0.9.3",
    "license": "MIT",

    "exports": {
        ".": "./mod.ts",
        "./decorators": "./src/decorators/lib.ts",
        "./globals": "./src/dev/global.ts",
        "./host": "./src/host/index.ts",
        "./router": "./src/router/index.ts",
        "./router/defaults": "./src/router/defaults.ts",
        "./serve": "./src/serve/index.ts",
        "./metadata": "./src/libutils/metadata.ts",
        "./script": "./src/libutils/script.el.ts"
    },

    "imports": {
        "@cross/deepmerge": "jsr:@cross/deepmerge@^1.0.0",
        "@exts/list": "jsr:@exts/list@^0.3.5",
        "@std/http": "jsr:@std/http@^1.0.10",
        "@std/path": "jsr:@std/path@^1.0.8",
        "preact-render-to-string": "npm:preact-render-to-string@^6.5.11",
        "preact": "npm:preact@^10.24.3"
    },
    "lint": {
        "include": ["deno.json", "mod.ts", "src/**/*.ts"],
        "rules": {
            "include": [
                "camelcase",
                "explicit-module-boundary-types",
                "single-var-declarator",
                "verbatim-module-syntax"
            ]
        }
    }
}
